{
  "name": "stagecoach-cli",
  "version": "0.0.0",
  "type": "module",
  "description": "UK bus data CLI: timetables, routes, fares, and live positions from BODS",
  "files": [
    "dist/cli",
    "dist/cli.cmd",
    "dist/*-bun-*"
  ],
  "bin": {
    "stagecoach-cli": "dist/cli"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "crust build",
    "package": "crust build --package",
    "publish": "crust publish --stage-dir dist/npm",
    "start": "./dist/cli",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "check": "bun run lint && bun run typecheck",
    "test": "bun test",
    "ci": "bun install --frozen-lockfile && bun run check && bun test",
    "prepare": "bunx lefthook install"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@crustjs/core": "0.0.18",
    "@crustjs/crust": "0.0.24",
    "@crustjs/plugins": "0.1.1",
    "@types/bun": "1.3.14",
    "typescript": "^6",
    "lefthook": "2.1.9"
  }
}
