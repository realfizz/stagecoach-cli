{
  "name": "stagecoach-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "UK bus data CLI: timetables, routes, fares, and live positions from BODS",
  "files": [
    "dist/cli.js"
  ],
  "bin": {
    "stagecoach-cli": "dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --target=bun src/cli.ts --outfile dist/cli.js && printf '#!/usr/bin/env bun\\n' | cat - dist/cli.js > dist/cli.js.tmp && mv dist/cli.js.tmp dist/cli.js && chmod +x dist/cli.js",
    "start": "./dist/cli.js",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "check": "bun run lint && bun run typecheck",
    "test": "bun test",
    "ci": "bun install --frozen-lockfile && bun run check && bun test",
    "prepare": "bunx lefthook install"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realfizz/stagecoach-cli.git"
  },
  "bugs": {
    "url": "https://github.com/realfizz/stagecoach-cli/issues"
  },
  "homepage": "https://github.com/realfizz/stagecoach-cli#readme",
  "keywords": [
    "uk",
    "bus",
    "bods",
    "transit",
    "cli",
    "agent",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@crustjs/core": "0.0.18",
    "@crustjs/crust": "0.0.24",
    "@crustjs/plugins": "0.1.1",
    "@types/bun": "1.3.14",
    "typescript": "^6",
    "lefthook": "2.1.9"
  }
}
